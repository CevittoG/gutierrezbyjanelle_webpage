# Copy to .env.local and fill in real values. Never commit .env.local.

# Password for the /quote-calc gate (used by /api/quote-auth).
QUOTE_CALC_PASSWORD=

# HMAC secret used to sign the /quote-calc session cookie. Must be at least
# 32 characters. Generate with:  openssl rand -base64 48
# Rotating this invalidates every active session.
QUOTE_CALC_SESSION_SECRET=

# --- Google Sheets persistence for /quote-calc drafts ---
#
# Create a Google Cloud service account, enable the Sheets API, and download
# the JSON key. Share the target spreadsheet with the service account email
# as "Editor". Then set:
#
#   GOOGLE_SHEETS_SA_EMAIL  — the service account's "client_email" field.
#   GOOGLE_SHEETS_SA_PRIVATE_KEY — the "private_key" field. PEM contents,
#     newlines escaped as \n. Wrap in quotes in your .env file.
#   GOOGLE_SHEETS_DOC_ID — the spreadsheet ID from the sheet URL
#     (https://docs.google.com/spreadsheets/d/<THIS_PART>/edit).
#
# The sheet must have a tab named "Quotes". The app writes the header row
# (now A1:R1 — adds the Phase 3 portal columns N–R) and the data rows; create
# the tab itself once by hand. Phase 1 also reads "Settings" and "Items" tabs.
GOOGLE_SHEETS_SA_EMAIL=
GOOGLE_SHEETS_SA_PRIVATE_KEY=
GOOGLE_SHEETS_DOC_ID=

# --- Phase 3: client portal + Drive proofs ---
#
# Each saved quote gets a Drive subfolder (proofs + the printed-quote PDF). The
# app CREATES that subfolder and READS its contents, but never uploads file
# content. This needs two extra OAuth scopes on the same service account —
# drive.file (create the subfolder) and drive.readonly (read the proofs Janelle
# uploads, which she owns). Both are already requested in lib/quote-calc-sheets.ts.
#
# One-time setup: create a root folder named "GBJ Quotes" in Drive and share it
# with the service-account email as **Editor** (not Viewer — the SA must be able
# to create subfolders in it). Put that folder's id here:
GOOGLE_DRIVE_PARENT_FOLDER_ID=
#
# Optional. If set, the app grants this email Editor on each subfolder it
# creates, guaranteeing Janelle can upload into it even if Drive's permission
# inheritance is flaky on consumer (gmail) accounts. Leave blank to rely on
# inheritance from the shared parent.
GBJ_QUOTES_OWNER_EMAIL=
