# Copy to .env.local and fill in real values. Never commit .env.local.

# Password for the /quote-calc gate (used by /api/quote-auth).
QUOTE_CALC_PASSWORD=

# HMAC secret used to sign the /quote-calc session cookie. Must be at least
# 32 characters. Generate with:  openssl rand -base64 48
# Rotating this invalidates every active session.
QUOTE_CALC_SESSION_SECRET=

# --- Google Sheets persistence for /quote-calc drafts ---
#
# Create a Google Cloud service account, enable the Sheets API, and download
# the JSON key. Share the target spreadsheet with the service account email
# as "Editor". Then set:
#
#   GOOGLE_SHEETS_SA_EMAIL  — the service account's "client_email" field.
#   GOOGLE_SHEETS_SA_PRIVATE_KEY — the "private_key" field. PEM contents,
#     newlines escaped as \n. Wrap in quotes in your .env file.
#   GOOGLE_SHEETS_DOC_ID — the spreadsheet ID from the sheet URL
#     (https://docs.google.com/spreadsheets/d/<THIS_PART>/edit).
#
# The sheet must have a tab named "Quotes" with header row A1:M1 matching the
# column names documented in lib/quote-calc-sheets.ts. The app will create
# rows but will NOT create the tab or write the header — do that once by hand.
GOOGLE_SHEETS_SA_EMAIL=
GOOGLE_SHEETS_SA_PRIVATE_KEY=
GOOGLE_SHEETS_DOC_ID=
